# CyberLens Environment Configuration
# Copy to .env and customize

# PostgreSQL
POSTGRES_USER=cyberlens
POSTGRES_PASSWORD=cyberlens_secret_2024
POSTGRES_DB=cyberlens
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cyberlens_neo4j_2024

# JWT
JWT_SECRET_KEY=change_this_to_a_random_secret_key_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Configuration
LLM_MODEL=local
LLM_API_URL=http://ollama:11434/api/generate
LLM_API_KEY=

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://frontend:3000"]

# Upload
MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=/app/uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
